<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_color"
    >
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/teachImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_avatar_placeholder"  />

        <TextView
            android:textColor="@color/black"
            android:id="@+id/name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_toRightOf="@id/teachImage"
            android:text="PROF. SARAH GERONIMO"
            android:textStyle="bold" />

        <TextView
            android:textColor="@color/black"
            android:id="@+id/email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/name"
            android:layout_marginLeft="10dp"
            android:layout_toRightOf="@id/teachImage"
            android:text="sarah.johnson@school.edu" />

        <TextView
            android:id="@+id/course"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/email"
            android:layout_marginLeft="10dp"
            android:layout_toRightOf="@id/teachImage"
            android:text="Computer Science"
            android:textColor="#c89d7c"
            android:textStyle="bold" />

        <!-- Find the Button at the bottom of headoffice_calendar_card.xml and add the ID -->
        <Button
            android:id="@+id/statusBtn"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/course"
            android:layout_margin="10dp"
            android:layout_toRightOf="@id/teachImage"
            android:backgroundTint="#80ef80"
            android:text="Present" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>