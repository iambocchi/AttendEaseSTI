<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFF8F0"
    app:cardCornerRadius="15dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/ivStudentAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_avatar_placeholder" />

        <!-- P A L E buttons -->
        <LinearLayout
            android:id="@+id/layoutAttendanceButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPresent"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/rounded_gray"

                android:gravity="center"
                android:text="P"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/btnAbsent"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/rounded_gray"
                android:gravity="center"
                android:text="A"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/btnLate"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/rounded_gray"
                android:gravity="center"
                android:text="L"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/btnExcused"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/rounded_gray"
                android:gravity="center"
                android:text="E"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <!-- Name + Year -->
        <LinearLayout
            android:id="@+id/layoutStudentInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/ivStudentAvatar"
            android:layout_toStartOf="@id/layoutAttendanceButtons"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ted Mosby"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tvStudentYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Year 3 - BS CS/Regular"
                android:textColor="#777777"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>