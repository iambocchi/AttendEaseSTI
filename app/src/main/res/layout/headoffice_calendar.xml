<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:background="@drawable/background"
    tools:context=".HeadOffices.headoffice_fragments.HeadOfficeCalendarFragment">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="25dp"
            android:background="@drawable/calendar_bg"
            android:elevation="8dp"
            android:focusedMonthDateColor="@color/brown"
            android:unfocusedMonthDateColor="@color/brown"
            android:weekDayTextAppearance="@style/CalendarWeekStyle"
            android:dateTextAppearance="@style/CalendarDateStyle"
            />
        <androidx.cardview.widget.CardView
            app:cardBackgroundColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/cards2"
            android:layout_centerHorizontal="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            android:layout_marginLeft="25dp"
            android:layout_marginRight="25dp"
            android:layout_marginBottom="25dp"
            android:layout_below="@+id/calendarView"
            android:background="@color/white">


            <!--        the items below the calendar-->
            <LinearLayout

                android:id="@+id/cardBelowCalendar"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <androidx.appcompat.widget.SearchView
                    android:id="@+id/searchTeachersCalendar"
                    style="@style/Widget.App.TextInputLayout.RoundedOutline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:background="@drawable/round"
                    app:iconifiedByDefault="false"
                    app:queryHint="Search teachers..."
                    app:queryBackground="@android:color/transparent"
                    android:theme="@style/SearchViewTheme" />

<!--                android:layout_marginLeft="20dp"-->
<!--                android:layout_marginRight="20dp"-->

                <androidx.recyclerview.widget.RecyclerView
                    android:layout_marginTop="20dp"

                    android:layout_marginBottom="20dp"
                    android:id="@+id/recyclerTeachersAttendanceCalendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />





            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>
</ScrollView>