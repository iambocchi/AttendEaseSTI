<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/userlogin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="24dp"

    tools:context=".Logins.LoginActivity">

    <!-- LOGO -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="1000dp"
        android:layout_height="120dp"
        android:layout_marginTop="60dp"
        android:layout_centerHorizontal="true"
        android:src="@drawable/mainlogo"
        android:scaleType="fitCenter" />

    <!-- TITLE -->
    <TextView
        android:id="@+id/Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Log In Now"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_below="@id/logo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/emailContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/Title"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="20dp"
        android:hint="Email"
        style="@style/Widget.App.TextInputLayout.RoundedOutline">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:paddingStart="20dp"
            android:textSize="16sp"
            android:textColor="@color/black"/>

    </com.google.android.material.textfield.TextInputLayout>
<!--    PASSWORD-->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/emailContainer"
        android:layout_marginTop="16dp"
        android:hint="Enter your password"
        style="@style/Widget.App.TextInputLayout.RoundedOutline"
        android:layout_marginHorizontal="20dp"
        app:endIconMode="password_toggle"
        app:endIconTint="#555555">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:textSize="16sp"
            android:textColor="@color/black"/>

    </com.google.android.material.textfield.TextInputLayout>



    <!-- SPINNER (TextInputLayout style dropdown) -->

<!--    <androidx.appcompat.widget.AppCompatSpinner-->
<!--        android:id="@+id/userType"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="60dp"-->
<!--        android:layout_below="@id/passwordContainer"-->
<!--        android:layout_marginTop="16dp"-->
<!--        android:paddingStart="20dp"-->
<!--        android:paddingEnd="40dp"-->
<!--        android:background="@drawable/rounded_spinner_pink"-->
<!--        android:spinnerMode="dropdown"-->
<!--        android:popupBackground="@android:color/white"/>-->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilautocomplete"
        android:layout_below="@id/passwordContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Choose your role"
        android:layout_marginTop="16dp"

      style="@style/Widget.App.TextInputLayout.RoundedOutline"

        app:endIconMode="dropdown_menu">

        <AutoCompleteTextView

            android:id="@+id/userType"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:textSize="16sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginHorizontal="20dp"
            android:inputType="none"
            android:popupBackground="@android:color/white"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- LOGIN BUTTON -->
    <Button
        android:layout_marginHorizontal="20dp"
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@id/tilautocomplete"
        android:layout_marginTop="32dp"
        android:text="Log in"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:backgroundTint="#B87C37" />

    <!-- FORGOT PASSWORD -->
    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password"
        android:textColor="#4A69BD"
        android:layout_below="@id/btnLogin"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp" />

</RelativeLayout>