<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

<!--    <ImageView-->
<!--    android:id="@+id/ivMenu"-->
<!--    android:layout_width="32dp"-->
<!--    android:layout_height="32dp"-->
<!--    android:layout_marginStart="16dp"-->
<!--    android:layout_marginTop="16dp"-->
<!--    android:src="@drawable/burger_menu"-->
<!--    app:layout_constraintStart_toStartOf="parent"-->
<!--    app:layout_constraintTop_toTopOf="parent" />-->

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivProfilePic"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="16dp"
        android:padding="2dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_avatar_placeholder"
        app:layout_constraintStart_toEndOf="@id/ivMenu"
        app:layout_constraintTop_toTopOf="@id/ivMenu"
        app:shapeAppearanceOverlay="@style/CircleImage" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/ivProfilePic"
        app:layout_constraintStart_toEndOf="@id/ivProfilePic"
        app:layout_constraintTop_toTopOf="@id/ivProfilePic">

        <TextView
            android:id="@+id/student_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_text"
            android:textColor="#333333"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student"
            android:textColor="#666666"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/ivProfilePic">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Student Information"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Basics"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Campus : "
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/student_campus"
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_text"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                <TextView
                    android:textColor="@color/profile_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Academic level : "
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/student_academic_level"
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_text"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Section : "
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/student_section"
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_text"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Program : "
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/student_program"
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_text"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Year level : "
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/yearlevel_section"
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_text"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Student ID : "
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/student_id"
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_text"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Location: "
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/student_location"
                        android:textColor="@color/profile_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_text"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <TextView

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="24dp"
                android:text="Contact"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/student_email"
                android:textColor="@color/profile_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="8dp"
                android:text="Email: andreacrus@school.com"
                android:textSize="13sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>