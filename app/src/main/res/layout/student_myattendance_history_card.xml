<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFF1E1"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#E9D7C3"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Left: date info -->
        <LinearLayout
            android:id="@+id/layoutDateInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feb"
                android:textColor="#8D6E63"
                android:textSize="11sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" "
                android:textSize="11sp" />
            <TextView
                android:id="@+id/dayAndYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17, 2026"
                android:textColor="#8D6E63"
                android:textSize="11sp" />
        </LinearLayout>


        </LinearLayout>

        <!-- Right: arrow -->
        <ImageView
            android:id="@+id/ivDropdownArrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/arrow_down_float" />

        <!-- Center-right: Present badge -->
        <LinearLayout
            android:id="@+id/layoutStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/ivDropdownArrow"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_present"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ Present"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp" />

        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>