<!--    INPUT TEXT-->
    <style name="Widget.App.TextInputLayout.RoundedOutline"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <item name="boxBackgroundMode">outline</item>

        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <item name="boxCornerRadiusTopStart">28dp</item>
        <item name="boxCornerRadiusTopEnd">28dp</item>
        <item name="boxCornerRadiusBottomStart">28dp</item>
        <item name="boxCornerRadiusBottomEnd">28dp</item>

        <item name="boxBackgroundColor">@android:color/white</item>

        <!-- Important for visibility -->
        <item name="hintTextColor">@color/hint_colors</item>
        <item name="android:textColorHint">@color/hint_colors</item>

        <!-- Stroke color selector -->
        <item name="boxStrokeColor">@color/stroke_colors</item>

    </style>

